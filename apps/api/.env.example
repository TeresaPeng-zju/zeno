# Copy to .env and adjust as needed
DATABASE_URL=postgresql+psycopg://zeno:zeno@localhost:5432/zeno
CORS_ORIGINS=http://localhost:3000

# LLM provider: mock | openai
LLM_PROVIDER=mock
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# DeepSeek（仅用于决策面对照评测的外部 baseline；不进确定性引擎）
# DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Resource curation harness. During launch, `ingest --auto-publish` lets DeepSeek
# labels publish immediately after a successful fetch; dead links remain failed.
CURATION_USER_AGENT=ZenoResourceCurator/1.0 (+your-contact-url)
CURATION_FETCH_TIMEOUT=15
CURATION_MAX_CHARS=12000
CURATION_AUTO_APPROVE_THRESHOLD=0.9

# 0G Compute —— 去中心化、可验证推理（OpenAI 兼容 Router）。
# 配了 ZG_API_KEY，Zeno 的「表达层」(诊断 voice) 就跑在 0G 上；决策仍在确定性引擎。
# 每次生成返回可链上验证的 request id（TEE 背书）。在 https://pc.0g.ai 拿 key + 选模型。
# ZG_API_KEY=sk-...
ZG_BASE_URL=https://router-api.0g.ai/v1
ZG_MODEL=zai-org/GLM-5-FP8

# Embedding provider: mock | openai | bge
# BGE-M3 原生 1024 维；本项目补零到现有 pgvector 的 1536 维，余弦相似度不变。
EMBEDDING_PROVIDER=bge
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
BGE_MODEL=BAAI/bge-m3
BGE_DEVICE=cpu
BGE_BATCH_SIZE=16
BGE_CACHE_DIR=.cache/huggingface/hub

# Questionnaire orchestrator
MAX_QUESTIONS=18
UNCERTAINTY_THRESHOLD=0.2
